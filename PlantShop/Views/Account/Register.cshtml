@model PlantShop.Models.TbAccount
@{
    ViewData["Title"] = "Đăng ký";

}
<style>
    .register-bg {
        background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('/assets/images/bg_1.jpg') center/cover no-repeat;
        height: 100vh;
        position: relative;
    }

    .register-container {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .register-box {
        width: 380px;
        background: #fff;
        padding: 30px;
        border-radius: 16px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

        .register-box h3 {
            text-align: center;
            color: #2e7d32;
            margin-bottom: 20px;
        }

        .register-box label {
            font-weight: 600;
            margin-bottom: 5px;
            display: block;
        }

        .register-box input {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border-radius: 8px;
            border: 1px solid #ccc;
            transition: 0.3s;
        }

            .register-box input:focus {
                border-color: #4CAF50;
                box-shadow: 0 0 6px rgba(76,175,80,0.3);
                outline: none;
            }

        .register-box button {
            width: 100%;
            padding: 12px;
            background: #4CAF50;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

            .register-box button:hover {
                background: #388e3c;
            }

        .register-box p {
            text-align: center;
            margin-top: 15px;
        }

        .register-box a {
            color: #4CAF50;
            font-weight: 600;
            text-decoration: none;
        }

            .register-box a:hover {
                text-decoration: underline;
            }

    .alert {
        padding: 10px;
        border-radius: 6px;
        margin-bottom: 15px;
    }
</style>

<section class="register-bg">

    <div class="register-container">
        <div class="register-box">
            <h3>Tạo Tài Khoản</h3>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form asp-action="Register" method="post">
                <label>Họ và tên</label>
                <input asp-for="FullName" placeholder="Nguyễn Văn A" required>

                <label>Email</label>
                <input asp-for="Email" type="email" placeholder="name@example.com" required>

                <label>Mật khẩu</label>
                <input asp-for="Password" type="password" required>

                <button type="submit">Đăng Ký</button>
            </form>

            <p>Đã có tài khoản? <a asp-action="Login">Đăng nhập</a></p>
        </div>
    </div>
</section>
