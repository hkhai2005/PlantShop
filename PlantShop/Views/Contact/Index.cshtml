@{
    ViewData["Title"] = "Contact";
}
<!-- ##### Breadcrumb Area Start ##### -->
<div class="breadcrumb-area">
    <!-- Top Breadcrumb Area -->
    <div class="top-breadcrumb-area bg-img bg-overlay d-flex align-items-center justify-content-center" style="background-image: url(../assets/img/bg-img/24.jpg);">
        <h2>Contact US</h2>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="#"><i class="fa fa-home"></i> Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Contact</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>
<!-- ##### Breadcrumb Area End ##### -->
<!-- ##### Contact Area Info Start ##### -->

<div class="contact-area-info section-padding-0-100" style="padding-bottom:30px;">
    <div class="container">
        <div class="row align-items-center justify-content-between p-4 rounded-4 shadow-sm bg-white border">

            <!-- Contact Thumbnail -->
            <div class="col-12 col-md-6 mb-4 mb-md-0">
                <div class="contact--thumbnail overflow-hidden rounded-3">
                    <img src="../assets/img/bg-img/25.jpg" class="img-fluid w-100" style="transition:0.3s;" alt="">
                </div>
            </div>

            <!-- Contact Info -->
            <div class="col-12 col-md-5">
                <!-- Section Heading -->
                <div class="section-heading mb-3">
                    <h2 class="fw-bold">CONTACT US</h2>
                    <p class="text-muted">We are improving our services to serve you better.</p>
                </div>

                <!-- Contact Information -->
                <div class="contact-information">
                    <p><span class="fw-semibold text-dark">Address:</span> 182 Lê Duẩn, Vinh, Nghệ An</p>
                    <p><span class="fw-semibold text-dark">Phone:</span> 0238 3855 452</p>
                    <p><span class="fw-semibold text-dark">Email:</span> vinhuni@gmail.com</p>
                    <p><span class="fw-semibold text-dark">Open hours:</span> Mon - Sun: 8 AM to 9 PM</p>
                    <p><span class="fw-semibold text-dark">Happy hours:</span> Sat: 2 PM to 4 PM</p>
                </div>               
            </div>
        </div>
    </div>
</div>
<!-- ##### Contact Area Info End ##### -->
<!-- ##### Contact Area Start ##### -->
<section class="contact-area">
    <div class="container ">
        <div class="row align-items-center justify-content-between p-4 rounded-4 shadow-sm bg-white border" >
            <div class="col-12 col-lg-5">
                <!-- Section Heading -->
                <div class="section-heading">
                    <h2>GET IN TOUCH</h2>
                    <p>Send us a message, we will call back later</p>
                </div>
                <!-- Contact Form Area -->
                <div class="contact-form-area mb-100">
                    <form action="#" method="post">
                        <div class="row">
                            <div class="col-12 col-md-6">
                                <div class="form-group">
                                    <input type="text" class="form-control" id="c_name" placeholder="Your Name">
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="form-group">
                                    <input type="text" class="form-control" id="c_phone" placeholder="Your Phone">
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-group">
                                    <input type="email" class="form-control" id="c_email" placeholder="Your Email">
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-group">
                                    <textarea class="form-control" name="message" id="c_message" cols="30" rows="10" placeholder="Message"></textarea>
                                </div>
                            </div>
                            <div class="col-12">
                                <button type="submit" id="c_submit" value="submit" class="btn alazea-btn mt-15">Send Message</button>                           
                            </div>
                        </div>
                    </form>                  
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <!-- Google Maps -->
                <div class="map-area mb-100">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3780.1101294462987!2d105.69574!3d18.659053399999998!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3139cddf0bf20f23%3A0x86154b56a284fa6d!2zVHLGsOG7nW5nIMSQ4bqhaSBo4buNYyBWaW5o!5e0!3m2!1svi!2s!4v1774145753787!5m2!1svi!2s" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                  </div>
            </div>
           
        </div>
    </div>
</section>
<!-- ##### Contact Area End ##### -->
@section Scripts {
    <script>
        $(document).ready(function () {
            $("#c_submit").click(function () {
                _name = $("#c_name").val();
                _phone = $("#c_phone").val();
                _email = $("#c_email").val();
                _message = $("#c_message").val();
                $.ajax({
                    url: "/Contact/Create",
                    type: "POST",
                    data: { name: _name, phone: _phone, email: _email, message: _message },
                    success: function (result) {
                        if (result != null) {
                            $("#c_name").val("");
                            $("#c_phone").val("");
                            $("#c_email").val("");
                            $("#c_message").val("");
                            toastr.success('Gửi thành công');
                        }
                        else {
                            toastr.success('Gửi không thành công');
                        }
                    }
                });
            });
        });
    </script>
}