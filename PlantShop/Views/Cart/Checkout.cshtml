@model PlantShop.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="breadcrumb-area">
    <!-- Top Breadcrumb Area -->
    <div class="top-breadcrumb-area bg-img bg-overlay d-flex align-items-center justify-content-center" style="background-image: url(/assets/img/bg-img/24.jpg);">
        <h2>Giỏ hàng</h2>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="#"><i class="fa fa-home"></i> Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Giỏ hàng</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>
<!-- Breadcrumb Area End -->
<!-- Checkout Area Start -->
<section class="checkout-area section-padding-100">
    <div class="container">
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row">
            <div class="col-12 col-lg-7">
                <div class="checkout-details bg-white p-4 rounded shadow-sm">
                    <h5 class="mb-4">Thông tin giao hàng</h5>

                    <form asp-action="Checkout" method="post" id="checkout-form">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <div class="col-12 mb-3">
                                <label asp-for="CustomerName" class="form-label fw-bold">Họ tên <span class="text-danger">*</span></label>
                                <input asp-for="CustomerName" class="form-control" placeholder="Nhập họ tên">
                                <span asp-validation-for="CustomerName" class="text-danger small"></span>
                            </div>

                            <div class="col-12 col-md-6 mb-3">
                                <label asp-for="Phone" class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                                <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại">
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>

                            <div class="col-12 col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" class="form-control" placeholder="Nhập email">
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="Address" class="form-label fw-bold">Địa chỉ <span class="text-danger">*</span></label>
                                <input asp-for="Address" class="form-control" placeholder="Số nhà, tên đường, tên khu phố...">
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>

                            <div class="col-12 col-md-4 mb-3">
                                <label asp-for="Province" class="form-label">Tỉnh/Thành phố</label>
                                <input asp-for="Province" class="form-control" placeholder="TP.HCM, Hà Nội...">
                            </div>

                            <div class="col-12 col-md-4 mb-3">
                                <label asp-for="District" class="form-label">Quận/Huyện</label>
                                <input asp-for="District" class="form-control" placeholder="Quận 1, Cầu Giấy...">
                            </div>

                            <div class="col-12 col-md-4 mb-3">
                                <label asp-for="Ward" class="form-label">Phường/Xã</label>
                                <input asp-for="Ward" class="form-control" placeholder="Bến Nghé...">
                            </div>

                            <div class="col-12 mb-3">
                                <label asp-for="Note" class="form-label">Ghi chú đơn hàng</label>
                                <textarea asp-for="Note" class="form-control" rows="3"
                                          placeholder="Ghi chú về thời gian giao hàng, quà tặng kèm..."></textarea>
                            </div>

                            <div class="col-12 mb-3">
                                <label class="form-label fw-bold">Phương thức thanh toán <span class="text-danger">*</span></label>
                                <div class="payment-methods">
                                    <div class="form-check mb-2 p-3 border rounded">
                                        <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="COD" id="cod" checked>
                                        <label class="form-check-label" for="cod">
                                            <i class="fa fa-truck text-success"></i> <strong>Thanh toán khi nhận hàng (COD)</strong>
                                            <small class="d-block text-muted">Thanh toán bằng tiền mặt khi nhận hàng</small>
                                        </label>
                                    </div>
                                    <div class="form-check mb-2 p-3 border rounded">
                                        <input class="form-check-input" type="radio" asp-for="PaymentMethod" value="BankTransfer" id="bank">
                                        <label class="form-check-label" for="bank">
                                            <i class="fa fa-university text-primary"></i> <strong>Chuyển khoản ngân hàng</strong>
                                            <small class="d-block text-muted">Chuyển khoản qua ngân hàng sau khi đặt hàng</small>
                                        </label>
                                    </div>
                                </div>
                                <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                            </div>
                        </div>
                    </form>
                    <div class="payment-method">
                        <div class="payment-accordion">
                            <form method="POST" asp-action="CreatePaymentUrlVnpay" asp-controller="Payment">
                                <input type="hidden" name="Name" id="vnpayName" value="nguyen van a" />
                                <input type="hidden" name="Amount" value="100000" />
                                <input type="hidden" name="OrderDescription" value="Thanh toán qua VnPay " />
                                <input type="hidden" name="OrderType" value="other" />
                                <button class="btn btn-danger" name="PayUrl" type="submit">Pay with VnPay</button>
                            </form>

                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-5 mt-4 mt-lg-0">
                <div class="order-summary bg-light p-4 rounded shadow-sm " style="top: 20px;">
                    <h5 class="mb-3">Đơn hàng của bạn</h5>
                    <div id="order-summary-content">
                        <div class="text-center py-3">
                            <div class="spinner-border text-success" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Đang tải giỏ hàng...</p>
                        </div>
                    </div>
                    <button type="submit" form="checkout-form" class="btn btn-success w-100 py-2 fw-bold mt-3">
                        <i class="fa fa-check-circle"></i> Đặt hàng ngay
                    </button>
                    <div class="text-center mt-3">
                        <a href="/Cart" class="text-muted">
                            <i class="fa fa-arrow-left"></i> Quay lại giỏ hàng
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Checkout Area End -->

<style>
    .checkout-details {
        background: #fff;
    }

    .payment-methods .form-check {
        cursor: pointer;
        transition: all 0.3s;
    }

        .payment-methods .form-check:hover {
            border-color: #28a745 !important;
            background: #f0fff0;
        }

    .payment-methods .form-check-input:checked + .form-check-label {
        color: #28a745;
    }

    .order-summary {
        position: sticky;
        top: 20px;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Load order summary
            function loadOrderSummary() {
                $.ajax({
                    url: '/Cart/GetOrderSummary',
                    type: 'GET',
                    success: function(data) {
                        $('#order-summary-content').html(data);
                    }
                });
            }
            loadOrderSummary();
        });
    </script>
}