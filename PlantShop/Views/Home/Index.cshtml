@{
    ViewData["Title"] = "Trang chủ";
}
<!-- ##### Hero Area Start ##### -->
<section class="hero-area">
    <div class="hero-post-slides owl-carousel">

        <!-- Single Hero Post -->
        <div class="single-hero-post bg-overlay">
            <!-- Post Image -->
            <div class="slide-img bg-img" style="background-image: url(../assets/img/bg-img/1.jpg);"></div>
            <div class="container h-100">
                <div class="row h-100 align-items-center">
                    <div class="col-12">
                        <!-- Post Content -->
                        <div class="hero-slides-content text-center">
                            <h2>Cây xanh tồn tại hòa quyện cùng thời tiết và những tia nắng bao quanh</h2>
                            <p>Chúng tôi mang đến không gian xanh mát, trong lành cho ngôi nhà của bạn. Với đội ngũ chuyên nghiệp và tận tâm, mọi nhu cầu về cây cảnh đều được đáp ứng một cách hoàn hảo nhất.</p>
                            <div class="welcome-btn-group">
                                <a href="/Shop" class="btn alazea-btn mr-30">BẮT ĐẦU NGAY</a>
                                <a href="/Contact" class="btn alazea-btn active">LIÊN HỆ</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Single Hero Post -->
        <div class="single-hero-post bg-overlay">
            <!-- Post Image -->
            <div class="slide-img bg-img" style="background-image: url(../assets/img/bg-img/2.jpg);"></div>
            <div class="container h-100">
                <div class="row h-100 align-items-center">
                    <div class="col-12">
                        <!-- Post Content -->
                        <div class="hero-slides-content text-center">
                            <h2>Kiến tạo không gian xanh – Nâng tầm cuộc sống</h2>
                            <p>Dịch vụ chăm sóc cây trọn gói, thiết kế cảnh quan sân vườn, cung cấp cây nội thất văn phòng. Hãy để chúng tôi giúp bạn tận hưởng những giá trị tinh túy nhất từ thiên nhiên.</p>
                            <div class="welcome-btn-group">
                                <a href="#" class="btn alazea-btn mr-30">BẮT ĐẦU NGAY</a>
                                <a href="#" class="btn alazea-btn active">LIÊN HỆ</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
<!-- ##### Hero Area End ##### -->
<!-- ##### Service Area Start ##### -->
<section class="our-services-area bg-gray section-padding-100-0">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <!-- Section Heading -->
                <div class="section-heading text-center">
                    <h2>DỊCH VỤ CỦA CHÚNG TÔI</h2>
                    <p>Chúng tôi mang đến giải pháp toàn diện cho không gian xanh của bạn</p>
                </div>
            </div>
        </div>

        <div class="row justify-content-between">
            <div class="col-12 col-lg-5">
                <div class="alazea-service-area mb-100">

                    <!-- Single Service Area -->
                    <div class="single-service-area d-flex align-items-center wow fadeInUp" data-wow-delay="100ms">
                        <!-- Icon -->
                        <div class="service-icon mr-30">
                            <img src="../assets/img/core-img/s1.png" alt="">
                        </div>
                        <!-- Content -->
                        <div class="service-content">
                            <h5>Chăm Sóc Cây Chuyên Nghiệp</h5>
                            <p>Đội ngũ kỹ thuật viên giàu kinh nghiệm sẽ chăm sóc cây trồng định kỳ, đảm bảo cây luôn xanh tốt và phát triển khỏe mạnh.</p>
                        </div>
                    </div>

                    <!-- Single Service Area -->
                    <div class="single-service-area d-flex align-items-center wow fadeInUp" data-wow-delay="300ms">
                        <!-- Icon -->
                        <div class="service-icon mr-30">
                            <img src="../assets/img/core-img/s2.png" alt="">
                        </div>
                        <!-- Content -->
                        <div class="service-content">
                            <h5>Vệ Sinh & Xịt Rửa Áp Lực</h5>
                            <p>Làm sạch sân vườn, lối đi, tường rào, khôi phục vẻ đẹp ban đầu cho không gian ngoại thất một cách nhanh chóng và hiệu quả.</p>
                        </div>
                    </div>

                    <!-- Single Service Area -->
                    <div class="single-service-area d-flex align-items-center wow fadeInUp" data-wow-delay="500ms">
                        <!-- Icon -->
                        <div class="service-icon mr-30">
                            <img src="../assets/img/core-img/s3.png" alt="">
                        </div>
                        <!-- Content -->
                        <div class="service-content">
                            <h5>Cắt Tỉa Cây & Dịch Vụ Cây Xanh</h5>
                            <p>Tỉa cành, tạo dáng, xử lý cây cao, cây có nguy cơ gãy đổ. Đảm bảo an toàn và thẩm mỹ cho toàn bộ khu vườn của bạn.</p>
                        </div>
                    </div>

                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="alazea-video-area bg-overlay mb-100">
                    <img src="../assets/img/bg-img/23.jpg" alt="">
                    <a href="http://www.youtube.com/watch?v=7HKoqNJtMTQ" class="video-icon">
                        <i class="fa fa-play" aria-hidden="true"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ##### Service Area End ##### -->
<!-- ##### About Area Start ##### -->
<section class="about-us-area section-padding-100-0">
