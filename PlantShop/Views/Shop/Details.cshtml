@model PlantShop.Models.TbProduct
@{  
    List<TbProduct> productComments = ViewBag.ProductComment;
    ViewData["Title"] = Model.Title;
}

<!-- ##### Breadcrumb Area Start ##### -->
<div class="breadcrumb-area">
    <div class="top-breadcrumb-area bg-img bg-overlay d-flex align-items-center justify-content-center" style="background-image: url(../assets/img/bg-img/24.jpg);">
        <h2>SHOP DETAILS</h2>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/"><i class="fa fa-home"></i> Home</a></li>
                        <li class="breadcrumb-item"><a href="/Shop">Shop</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>
<!-- ##### Breadcrumb Area End ##### -->
<!-- ##### Single Product Details Area Start ##### -->
<section class="single_product_details_area mb-50">
    <div class="produts-details--content mb-50">
        <div class="container">
            <div class="row justify-content-between">
                <div class="col-12 col-md-6 col-lg-5">
                    <div class="single_product_thumb">
                        <div id="product_details_slider" class="carousel slide" data-ride="carousel">
                            <div class="carousel-inner">
                                <div class="carousel-item active">
                                    <a class="product-img" href="@Model.Image" title="Product Image">
                                        <img class="d-block w-100" src="@Model.Image" alt="@Model.Title">
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="single_product_desc">
                        <h4 class="title">@Model.Title</h4>

                        @if (Model.PriceSale > 0 && Model.PriceSale < Model.Price)
                        {
                            <h4 class="price">
                                <del class="text-muted">@Model.Price?.ToString("N0")₫</del>
                                <span class="text-danger">@Model.PriceSale?.ToString("N0")₫</span>
                            </h4>
                        }
                        else
                        {
                            <h4 class="price">@Model.Price?.ToString("N0")₫</h4>
                        }

                        <div class="short_overview">
                            <p>@Model.Description</p>
                        </div>

                        <div class="cart--area d-flex flex-wrap align-items-center">
                            <!-- Add to Cart Form -->
                            <div class="cart clearfix d-flex align-items-center">
                                <div class="quantity">
                                    <span class="qty-minus" onclick="decrementQty()"><i class="fa fa-minus" aria-hidden="true"></i></span>
                                    <input type="number" class="qty-text" id="qty" step="1" min="1" max="@(Model.Quantity ?? 99)" value="1">
                                    <span class="qty-plus" onclick="incrementQty()"><i class="fa fa-plus" aria-hidden="true"></i></span>
                                </div>
                                <button type="button" id="add-to-cart-detail" class="btn alazea-btn ml-15">Add to cart</button>
                            </div>
                            <!-- Wishlist & Compare -->
                            <div class="wishlist-compare d-flex flex-wrap align-items-center">
                                <a href="#" id="wishlist-btn" class="wishlist-btn ml-15" data-product-id="@Model.ProductId">
                                    <i class="icon_heart_alt"></i>
                                </a>
                            </div>
                        </div>

                        <div class="products--meta">
                            <p><span>SKU:</span> <span>@Model.Sku</span></p>
                            <p><span>Tags:</span> <span>@Model.Tags</span></p>
                            <p>
                                <span>Share on:</span>
                                <span>
                                    <a href="#"><i class="fa fa-facebook"></i></a>
                                    <a href="#"><i class="fa fa-twitter"></i></a>
                                    <a href="#"><i class="fa fa-pinterest"></i></a>
                                    <a href="#"><i class="fa fa-google-plus"></i></a>
                                </span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="product_details_tab clearfix">
                    <ul class="nav nav-tabs" role="tablist" id="product-details-tab">
                        <li class="nav-item">
                            <a href="#description" class="nav-link active" data-toggle="tab" role="tab">Description</a>
                        </li>
                        <li class="nav-item">
                            <a href="#reviews" class="nav-link" data-toggle="tab" role="tab">Reviews</a>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <div role="tabpanel" class="tab-pane fade show active" id="description">
                            <div class="description_area">
                                @Html.Raw(Model.Detail)
                            </div>
                        </div>
                        <div role="tabpanel" class="tab-pane fade" id="reviews">
                            <div class="reviews_area">
                                <div id="review-list">
                                    <!-- Sẽ load reviews bằng AJAX -->
                                </div>
                                <div class="submit_a_review_area mt-50">
                                    <h4>Submit A Review</h4>
                                    <form id="review-form" method="post">
                                        <div class="row">
                                            <div class="col-12">
                                                <div class="form-group d-flex align-items-center">
                                                    <span class="mr-15">Your Ratings:</span>
                                                    <div class="stars">
                                                        <input type="radio" name="star" class="star-1" id="star-1" value="1">
                                                        <label class="star-1" for="star-1">1</label>
                                                        <input type="radio" name="star" class="star-2" id="star-2" value="2">
                                                        <label class="star-2" for="star-2">2</label>
                                                        <input type="radio" name="star" class="star-3" id="star-3" value="3">
                                                        <label class="star-3" for="star-3">3</label>
                                                        <input type="radio" name="star" class="star-4" id="star-4" value="4">
                                                        <label class="star-4" for="star-4">4</label>
                                                        <input type="radio" name="star" class="star-5" id="star-5" value="5">
                                                        <label class="star-5" for="star-5">5</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12 col-md-6">
                                                <div class="form-group">
                                                    <label for="name">Name</label>
                                                    <input type="text" class="form-control" id="review-name" placeholder="Your name">
                                                </div>
                                            </div>
                                            <div class="col-12 col-md-6">
                                                <div class="form-group">
                                                    <label for="email">Email</label>
                                                    <input type="email" class="form-control" id="review-email" placeholder="Your email">
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-group">
                                                    <label for="comments">Comments</label>
                                                    <textarea class="form-control" id="review-detail" rows="5" placeholder="Your review..."></textarea>
                                                </div>
                                            </div>
                                            <div class="col-12">
                                                <button type="button" id="submit-review" class="btn alazea-btn">Submit Your Review</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ##### Single Product Details Area End ##### -->
<!-- Toast Notification -->
<div class="toast-notification" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999; display: none;">
    <div class="toast bg-success text-white p-3 rounded">
        <div class="d-flex align-items-center">
            <i class="fa fa-check-circle fa-2x me-2"></i>
            <div>
                <strong>Thành công!</strong>
                <span class="toast-message">Đã thêm vào giỏ hàng</span>
            </div>
        </div>
    </div>
</div>

<style>
    .toast-notification {
        animation: slideIn 0.3s ease;
        z-index: 9999;
    }
   

    .quantity {
        display: flex;
        align-items: center;
    }

    .qty-text {
        width: 60px;
        text-align: center;
        border: 1px solid #ddd;
        border-radius: 5px;
        padding: 8px;
    }

    .qty-minus, .qty-plus {
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f5f5;
        border: 1px solid #ddd;
        cursor: pointer;
    }

    .qty-minus {
        border-radius: 5px 0 0 5px;
    }

    .qty-plus {
        border-radius: 0 5px 5px 0;
    }
</style>

@section Scripts {
    <script>
        function showToast(message, isError = false) {
            $('.toast-notification .toast').removeClass('bg-success bg-danger').addClass(isError ? 'bg-danger' : 'bg-success');
            $('.toast-message').text(message);
            $('.toast-notification').fadeIn(300).delay(2000).fadeOut(300);
        }

        function updateCartCount() {
            $.ajax({
                url: '/Cart/GetCartCount',
                type: 'GET',
                success: function(data) {
                    $('#cart-count').text(data);
                }
            });
        }

        function decrementQty() {
            var input = $('#qty');
            var val = parseInt(input.val());
            if (val > 1) input.val(val - 1);
        }

        function incrementQty() {
            var input = $('#qty');
            var val = parseInt(input.val());
            var max = parseInt(input.attr('max')) || 99;
            if (val < max) input.val(val + 1);
        }

        // Thêm vào giỏ hàng từ trang detail
        $('#add-to-cart-detail').click(function() {
            var productId = @Model.ProductId;
            var quantity = $('#qty').val();

            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productId: productId, quantity: quantity },
                success: function(res) {
                    if (res.success) {
                        showToast(res.message);
                        updateCartCount();
                    } else {
                        showToast(res.message, true);
                    }
                },
                error: function() {
                    showToast('Có lỗi xảy ra, vui lòng thử lại', true);
                }
            });
        });

        // Yêu thích sản phẩm
        $('#wishlist-btn').click(function(e) {
            e.preventDefault();
            var productId = $(this).data('product-id');

            $.ajax({
                url: '/Wishlist/AddToWishlist',
                type: 'POST',
                data: { productId: productId },
                success: function(res) {
                    if (res.success) {
                        showToast('Đã thêm vào danh sách yêu thích');
                        $('#wishlist-btn i').addClass('text-danger');
                    } else {
                        showToast(res.message, true);
                    }
                }
            });
        });

        // Gửi đánh giá
        $('#submit-review').click(function() {
            var name = $('#review-name').val();
            var email = $('#review-email').val();
            var star = $('input[name="star"]:checked').val();
            var detail = $('#review-detail').val();

            if (!name || !email || !star || !detail) {
                showToast('Vui lòng điền đầy đủ thông tin', true);
                return;
            }

            $.ajax({
                url: '/Product/AddReview',
                type: 'POST',
                data: {
                    productId: @Model.ProductId,
                    name: name,
                    email: email,
                    star: star,
                    detail: detail
                },
                success: function(res) {
                    if (res.success) {
                        showToast('Cảm ơn bạn đã đánh giá!');
                        $('#review-name, #review-email, #review-detail').val('');
                        $('input[name="star"]').prop('checked', false);
                    } else {
                        showToast(res.message, true);
                    }
                }
            });
        });
    </script>
}