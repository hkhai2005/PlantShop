@model List<PlantShop.Models.TbProduct>
@{
    ViewData["Title"] = "Shop";
}

<!-- ##### Breadcrumb Area Start ##### -->
<div class="breadcrumb-area">
    <div class="top-breadcrumb-area bg-img bg-overlay d-flex align-items-center justify-content-center" style="background-image: url(../assets/img/bg-img/24.jpg);">
        <h2>Shop</h2>
    </div>
    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/"><i class="fa fa-home"></i> Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Shop</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- ##### Breadcrumb Area End ##### -->
<!-- ##### Shop Area Start ##### -->
<section class="shop-page section-padding-0-100">
    <div class="container">
        <div class="row">
            <!-- Shop Sorting Data -->
            <div class="col-12">
                <div class="shop-sorting-data d-flex flex-wrap align-items-center justify-content-between">
                    <div class="shop-page-count">
                        <p>Hiển thị @Model.Count kết quả</p>
                    </div>
                    <div class="search_by_terms">

                        <form method="get">

                            <!-- Giữ keyword khi sort -->
                            <input type="hidden"
                                   name="keyword"
                                   value="@ViewBag.Keyword" />

                            <select class="custom-select widget-title"
                                    name="sort"
                                    onchange="this.form.submit()">

                                <option value="0">Sort by Default</option>

                                <option value="1" selected="@(ViewBag.Sort == 1)">
                                    Sort by Newest
                                </option>

                                <option value="2" selected="@(ViewBag.Sort == 2)">
                                    Sort by Price: Low to High
                                </option>

                                <option value="3" selected="@(ViewBag.Sort == 3)">
                                    Sort by Price: High to Low
                                </option>

                            </select>

                        </form>
    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <!-- Sidebar Area -->
            <div class="col-12 col-md-4 col-lg-3">
                <div class="shop-sidebar-area">
                    <!-- Shop Widget Price -->
                    <div class="shop-widget price mb-50">
                        <h4 class="widget-title">Lọc Giá </h4>
                        <div class="widget-desc">
                            <form method="get" action="/Shop">

                                <input type="hidden"
                                       name="keyword"
                                       value="@ViewBag.Keyword" />

                                <input type="hidden"
                                       name="sort"
                                       value="@ViewBag.Sort" />

                                <select class="custom-select widget-title"
                                        name="price"
                                        onchange="this.form.submit()">

                                    <option value="">All Prices</option>

                                    <option value="1">
                                        Under 100.000₫
                                    </option>

                                    <option value="2">
                                        100.000₫ - 300.000₫
                                    </option>

                                    <option value="3">
                                        Above 300.000₫
                                    </option>

                                </select>

                            </form>
                        </div>
                    </div>

</div>

                    <!-- Shop Widget Categories -->
                    <div class="shop-widget catagory mb-50">
                        <h4 class="widget-title">Sản Phẩm</h4>
                        <div class="widget-desc" id="category-list">
                            <!-- Categories sẽ load bằng AJAX hoặc bind từ ViewBag -->
                        </div>
                    </div>
                </div>
            </div>

            <!-- All Products Area -->
        <div class="col-12 ">
            @* //col-md-8 col-lg-9 *@
                <div class="shop-products-area">
                    <div class="row" id="product-list">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                string sUrl = $"/product/{item.Alias}-{item.ProductId}.html";
                                <div class="col-12 col-sm-6 col-lg-4">
                                    <div class="single-product-area mb-50">
                                        <div class="product-img">
                                            <a href="@sUrl">
                                                <img src="@(string.IsNullOrEmpty(item.Image) ? "/assets/img/bg-img/default.jpg" : item.Image)" alt="@item.Title">
                                            </a>
                                            @if (item.IsBestSeller == true)
                                            {
                                                <div class="product-tag">
                                                    <a href="#">Best Seller</a>
                                                </div>
                                            }
                                            else if (item.IsNew == true)
                                            {
                                                <div class="product-tag sale-tag">
                                                    <a href="#">New</a>
                                                </div>
                                            }
                                            <div class="product-meta d-flex">
                                                <a href="#" class="wishlist-btn" data-product-id="@item.ProductId">
                                                    <i class="icon_heart_alt"></i>
                                                </a>
                                                <a href="#" class="add-to-cart-btn" data-product-id="@item.ProductId">
                                                    Add to cart
                                                </a>
                                                <a href="#" class="compare-btn" data-product-id="@item.ProductId">
                                                    <i class="arrow_left-right_alt"></i>
                                                </a>
                                            </div>
                                        </div>
                                        <div class="product-info mt-15 text-center">
                                            <a href="@sUrl">
                                                <p>@item.Title</p>
                                            </a>
                                            @if (item.PriceSale > 0 && item.PriceSale < item.Price)
                                            {
                                                <h6><del class="text-muted">@item.Price?.ToString("N0")₫</del> @item.PriceSale?.ToString("N0")₫</h6>
                                            }
                                            else
                                            {
                                                <h6>@item.Price?.ToString("N0")₫</h6>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12 text-center">
                                <p>Không có sản phẩm nào.</p>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            <li class="page-item"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item"><a class="page-link" href="#">3</a></li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ##### Shop Area End ##### -->
<!-- Toast Notification -->
<div class="toast-notification" style="position: fixed; bottom: 20px; right: 20px; z-index: 9999; display: none;">
    <div class="toast bg-success text-white p-3 rounded">
        <div class="d-flex align-items-center">
            <i class="fa fa-check-circle fa-2x me-2"></i>
            <div>
                <strong>Thành công!</strong>
                <span class="toast-message">Đã thêm vào giỏ hàng</span>
            </div>
        </div>
    </div>
</div>

<style>
    .product-meta {
        position: absolute;
        bottom: 10px;
        left: 0;
        right: 0;
        justify-content: center;
        gap: 10px;
        opacity: 0;
        transition: 0.3s;
    }

    .single-product-area:hover .product-meta {
        opacity: 1;
        bottom: 20px;
    }

    .add-to-cart-btn, .wishlist-btn, .compare-btn {
        background: #fff;
        padding: 8px 12px;
        border-radius: 5px;
        font-size: 12px;
        color: #333;
        text-decoration: none;
        transition: 0.3s;
    }

        .add-to-cart-btn:hover {
            background: #70c745;
            color: #fff;
        }

    .toast-notification {
        animation: slideIn 0.3s ease;
    }

</style>

@section Scripts {
    <script>
        function showToast(message) {
            $('.toast-message').text(message);
            $('.toast-notification').fadeIn(300).delay(2000).fadeOut(300);
        }

        function updateCartCount() {
            $.ajax({
                url: '/Cart/GetCartCount',
                type: 'GET',
                success: function(data) {
                    $('#cart-count').text(data);
                }
            });
        }

        // Thêm vào giỏ hàng
        $('.add-to-cart-btn').click(function(e) {
            e.preventDefault();
            var productId = $(this).data('product-id');

            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { productId: productId, quantity: 1 },
                success: function(res) {
                    if (res.success) {
                        showToast(res.message);
                        updateCartCount();
                    } else {
                        showToast(res.message);
                    }
                },
                error: function() {
                    showToast('Có lỗi xảy ra, vui lòng thử lại');
                }
            });
        });

        // Yêu thích sản phẩm
        $('.wishlist-btn').click(function(e) {
            e.preventDefault();
            var productId = $(this).data('product-id');

            $.ajax({
                url: '/Wishlist/AddToWishlist',
                type: 'POST',
                data: { productId: productId },
                success: function(res) {
                    if (res.success) {
                        showToast('Đã thêm vào yêu thích');
                    } else {
                        showToast('Vui lòng đăng nhập để sử dụng tính năng này');
                    }
                }
            });
        });

    </script>
}