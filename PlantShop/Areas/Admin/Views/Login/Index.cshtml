@model PlantShop.Models.TbAccount
@using PlantShop.Utilities

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>PlantShop Admin Login</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">

    <!-- Font Awesome -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            height: 100vh;
            background: linear-gradient(135deg,#11998e,#38ef7d);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-container {
            width: 950px;
            height: 550px;
            background: rgba(255,255,255,0.15);
            border-radius: 20px;
            overflow: hidden;
            display: flex;
            backdrop-filter: blur(10px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }

        /* LEFT */

        .login-left {
            flex: 1;
            background: url('/admin/dist/images/team.jpg');
            background-size: cover;
            background-position: center;
            position: relative;
        }

        .overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,0.35);
        }

        .welcome-text {
            position: absolute;
            bottom: 40px;
            left: 40px;
            color: white;
        }

        .welcome-text h1 {
            font-size: 40px;
            font-weight: bold;
        }

        .welcome-text p {
            font-size: 18px;
        }

        /* RIGHT */

        .login-right {
            flex: 1;
            background: white;
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .title {
            text-align: center;
            margin-bottom: 40px;
        }

        .title h2 {
            font-weight: bold;
            color: #11998e;
        }

        .title p {
            color: gray;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 25px;
        }

        .input-group-custom input {
            width: 100%;
            padding: 14px 45px;
            border-radius: 10px;
            border: 1px solid #ddd;
            outline: none;
            transition: 0.3s;
        }

        .input-group-custom input:focus {
            border-color: #11998e;
            box-shadow: 0 0 8px rgba(17,153,142,0.3);
        }

        .input-group-custom i {
            position: absolute;
            top: 16px;
            left: 15px;
            color: gray;
        }

        .toggle-password {
            position: absolute;
            right: 15px;
            top: 16px;
            cursor: pointer;
            color: gray;
        }

        .btn-login {
            width: 100%;
            border: none;
            padding: 14px;
            border-radius: 10px;
            background: linear-gradient(135deg,#11998e,#38ef7d);
            color: white;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

        .forgot {
            text-align: right;
            margin-bottom: 20px;
        }

        .forgot a {
            color: #11998e;
            text-decoration: none;
        }

        .register-link {
            margin-top: 25px;
            text-align: center;
        }

        .register-link a {
            color: #11998e;
            font-weight: bold;
            text-decoration: none;
        }

        .error-message {
            color: red;
            margin-bottom: 15px;
            text-align: center;
        }

        @@media(max-width: 900px) {

            .login-container {
                width: 95%;
                height: auto;
                flex-direction: column;
            }

            .login-left {
                height: 250px;
            }
        }

    </style>

</head>

<body>

    <div class="login-container">

        <!-- LEFT -->
        <div class="login-left">

            <div class="overlay"></div>

            <div class="welcome-text">
                <h1>PlantShop</h1>
                <p>Hệ thống quản lý cây cảnh thông minh</p>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="login-right">

            <div class="title">
                <h2>Đăng Nhập</h2>
                <p>Admin Dashboard</p>
            </div>

            <form asp-controller="Login"
                  asp-action="Index"
                  method="post">

                <!-- Username -->
                <div class="input-group-custom">

                    <i class="fa fa-user"></i>

                    <input asp-for="Username"
                           type="text"
                           placeholder="Tên tài khoản"
                           required>

                </div>

                <!-- Password -->
                <div class="input-group-custom">

                    <i class="fa fa-lock"></i>

                    <input asp-for="Password"
                           id="password"
                           type="password"
                           placeholder="Mật khẩu"
                           required>

                    <span class="toggle-password"
                          onclick="togglePassword()">
                        <i class="fa fa-eye"></i>
                    </span>

                </div>

                <!-- Error -->
                <div class="error-message">
                    @Function._Message
                </div>

                <!-- Forgot -->
                <div class="forgot">
                    <a href="#">Quên mật khẩu?</a>
                </div>

                <!-- Button -->
                <button type="submit"
                        class="btn-login">
                    ĐĂNG NHẬP
                </button>

            </form>

            <!-- Register -->
            <div class="register-link">

                Chưa có tài khoản?

                <a asp-controller="Register"
                   asp-action="Index">
                    Đăng ký
                </a>

            </div>

        </div>

    </div>

    <!-- JS -->

    <script>

        function togglePassword() {

            let password = document.getElementById("password");

            if (password.type === "password") {
                password.type = "text";
            }
            else {
                password.type = "password";
            }
        }

    </script>

</body>

</html>