@model PlantShop.Models.Video
@{
    ViewData["Title"] = "Sửa video";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<main class="app-content">
    <div class="app-title">
        <ul class="app-breadcrumb breadcrumb">
            <li class="breadcrumb-item">Quản lý video</li>
            <li class="breadcrumb-item"><a href="#">Sửa video</a></li>
        </ul>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="tile">
                <h3 class="tile-title">Chỉnh sửa video: @Model.Title</h3>
                <div class="tile-body">
                    <div asp-validation-summary="All" class="alert alert-danger"></div>

                    <form asp-action="Edit" method="post" class="row">
                        <input type="hidden" asp-for="VideoId" />
                        <input type="hidden" asp-for="Views" />
                        <input type="hidden" asp-for="CreatedDate" />
                        <input type="hidden" asp-for="CreatedBy" />

                        <div class="form-group col-md-8">
                            <label asp-for="Title" class="control-label">Tiêu đề <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control" required />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-4">
                            <label asp-for="YoutubeId" class="control-label">ID YouTube <span class="text-danger">*</span></label>
                            <input asp-for="YoutubeId" class="form-control" required />
                            <span asp-validation-for="YoutubeId" class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-12">
                            <label asp-for="Description" class="control-label">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-3">
                            <label asp-for="Duration" class="control-label">Thời lượng (giây)</label>
                            <input asp-for="Duration" class="form-control" type="number" />
                            <span asp-validation-for="Duration" class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-3">
                            <label asp-for="Category" class="control-label">Danh mục</label>
                            <input asp-for="Category" class="form-control" />
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-3">
                            <label asp-for="SortOrder" class="control-label">Thứ tự hiển thị</label>
                            <input asp-for="SortOrder" class="form-control" type="number" />
                            <span asp-validation-for="SortOrder" class="text-danger"></span>
                        </div>

                        <div class="form-group col-md-3">
                            <label asp-for="IsActive" class="control-label">Trạng thái</label>
                            <select asp-for="IsActive" class="form-control">
                                <option value="true">Hiển thị</option>
                                <option value="false">Ẩn</option>
                            </select>
                        </div>

                        <div class="form-group col-md-12">
                            <label>Preview video</label>
                            <div class="embed-responsive embed-responsive-16by9">
                                <iframe class="embed-responsive-item"
                                        src="https://www.youtube.com/embed/@Model.YoutubeId"
                                        frameborder="0"
                                        allowfullscreen>
                                </iframe>
                            </div>
                        </div>

                        <div class="form-group col-md-12">
                            <button class="btn btn-save" type="submit"><i class="fa fa-save"></i> Cập nhật</button>
                            <a asp-action="Index" class="btn btn-cancel"><i class="fa fa-times"></i> Hủy bỏ</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>