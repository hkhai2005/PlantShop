@model PlantShop.Models.TbMenu

@{
    ViewData["Title"] = "Create";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<main class="app-content">
<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-sm-6">
            @* <h1>Thêm Menu</h1> *@
        </div>
        <div class="col-sm-6 text-right">
            <ol class="breadcrumb float-sm-right">
                <li class="breadcrumb-item"><a href="#">Quản lý menu</a></li>
                <li class="breadcrumb-item active">Thêm menu</li>
            </ol>
        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <div class="card card-primary">
                <div class="card-header">
                    <h3 class="card-title">Thêm menu</h3>
                </div>

                <form asp-action="Create">
                    <div class="card-body">

                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group">
                            <label asp-for="Title">Tiêu đề</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Alias">Alias</label>
                            <input asp-for="Alias" class="form-control" />
                            <span asp-validation-for="Alias" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Description">Mô tả</label>
                            <input asp-for="Description" class="form-control" />
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Levels">Mức</label>
                            <input asp-for="Levels" class="form-control" />
                            <span asp-validation-for="Levels" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="ParentId">Menu cha</label>
                            <input asp-for="ParentId" class="form-control" />
                            <span asp-validation-for="ParentId" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Position">Vị trí</label>
                            <input asp-for="Position" class="form-control" />
                            <span asp-validation-for="Position" class="text-danger"></span>
                        </div>

                        <div class="form-group form-check">
                            <input class="form-check-input" asp-for="IsActive" />
                            <label class="form-check-label" asp-for="IsActive">Hiển thị</label>
                        </div>

                    </div>

                    <div class="card-footer">
                        <button type="submit" class="btn btn-primary">Thêm mới</button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Quay lại
                            </a>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>
</main>

