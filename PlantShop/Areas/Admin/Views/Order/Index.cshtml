@model IEnumerable<PlantShop.Models.TbOrder>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<main class="app-content">
    <div class="app-title">
        <ul class="app-breadcrumb breadcrumb side">
            <li class="breadcrumb-item active"><a href="#"><b>Danh sách đơn hàng</b></a></li>
        </ul>
        <div id="clock"></div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="tile">
                <div class="tile-body">

                    <!-- Form tìm kiếm và lọc -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <form method="get" class="row g-3">
                                <div class="col-md-3">
                                    <input type="text" name="searchTerm" class="form-control" placeholder="🔍 Mã đơn, KH, SĐT..." value="@ViewBag.SearchTerm" />
                                </div>
                                <div class="col-md-2">
                                    <select name="orderStatusId" class="form-control">
                                        <option value="">-- Tất cả trạng thái --</option>
                                        @foreach (var status in ViewBag.OrderStatusList as SelectList)
                                        {
                                            <option value="@status.Value" selected="@(ViewBag.SelectedStatus?.ToString() == status.Value)">
                                                @status.Text
                                            </option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-2">
                                    <input type="date" name="fromDate" class="form-control" value="@ViewBag.FromDate" placeholder="Từ ngày" />
                                </div>
                                <div class="col-md-2">
                                    <input type="date" name="toDate" class="form-control" value="@ViewBag.ToDate" placeholder="Đến ngày" />
                                </div>
                                <div class="col-md-3">
                                    <button type="submit" class="btn btn-primary"><i class="fa fa-search"></i> Tìm kiếm</button>
                                    <a asp-action="Index" class="btn btn-secondary"><i class="fa fa-refresh"></i> Làm mới</a>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Bảng dữ liệu -->
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered" id="sampleTable">
                            <thead>
                                <tr>
                                    <th>STT</th>
                                    <th>Mã đơn</th>
                                    <th>Khách hàng</th>
                                    <th>SĐT</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Số lượng</th>
                                    <th>Trạng thái</th>
                                    <th>Thanh toán</th>
                                    <th width="140">Chức năng</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int i = 1;
                                }
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@(i++)</td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@item.OrderId" class="text-primary fw-bold">
                                                @(item.Code ?? "DH" + item.OrderId)
                                            </a>
                                        </td>
                                        <td>@item.CustomerName</td>
                                        <td>@item.Phone</td>
                                        <td>@(item.CreatedDate?.ToString("dd/MM/yyyy HH:mm") ?? "--")</td>
                                        <td class="text-end fw-bold">@(item.TotalAmount?.ToString("N0"))đ</td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td>
                                            @if (item.OrderStatus != null)
                                            {
                                                string badgeClass = item.OrderStatus.Name switch
                                                {
                                    "Chờ xác nhận" or "Pending" => "bg-warning",
                                    "Đang giao" or "Shipping" => "bg-info",
                                    "Hoàn thành" or "Completed" => "bg-success",
                                    "Đã hủy" or "Cancelled" => "bg-danger",
                                    _ => "bg-secondary"
                                                };
                                                <span class="badge @badgeClass">@item.OrderStatus.Name</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@item.OrderStatusId</span>
                                            }
                                        </td>
                                        <td>
                                            @{
                                                string paymentBadge = item.PaymentStatus switch
                                                {
                                                    "Paid" => "bg-success",
                                                    "Unpaid" => "bg-warning",
                                                    "Refunded" => "bg-secondary",
                                                    _ => "bg-light text-dark"
                                                };
                                            }
                                            <span class="badge @paymentBadge">@item.PaymentStatus</span>
                                        </td>
                                        <td class="table-td-center">
                                            <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-primary btn-sm" title="Chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-primary btn-sm edit" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.OrderId" class="btn btn-primary btn-sm trash" title="Xóa">
                                                <i class="fas fa-trash-alt"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (!Model.Any())
                    {
                        <div class="alert alert-info text-center">Không có đơn hàng nào.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        // Xuất Excel
        $('#exportExcel').click(function() {
            var table = document.getElementById("sampleTable");
            var html = table.outerHTML;
            var url = 'data:application/vnd.ms-excel,' + encodeURIComponent(html);
            var downloadLink = document.createElement("a");
            document.body.appendChild(downloadLink);
            downloadLink.href = url;
            downloadLink.download = 'DanhSachDonHang.xls';
            downloadLink.click();
            document.body.removeChild(downloadLink);
        });
    </script>
}